// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}


model User {
  id        BigInt   @id @default(autoincrement())
  username  String?   @unique
  email     String   @unique
  password  String?
  firstName String?
  lastName  String?
  avatar    String? 
  bio       String? 
  websiteUrl   String? 
  githubUrl    String? 
  isVerified Boolean @default(false) // Trạng thái xác thực email, mặc định là false
  emailVerifiedAt DateTime? // Thời gian xác thực email, có thể null nếu chưa xác thực
  createdAt DateTime @default(now()) // tự động lưu thời gian tạo
  updatedAt DateTime  @default(now()) // tự động cập nhật thời gian khi có thay đổi

  posts     Post[] // 1 User sẽ có nhiều bài viết
  Comments  Comment[] // 1 User sẽ có nhiều comment

  @@map("users") // Đặt tên bảng trong database là "users"
}

model Post {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt // khóa ngoại liên kết đến User
  title     String
  description String? @db.Text
  slug      String   @unique
  image     String?
  content   String?  @db.Text
  minRead   Int?     // Thời gian đọc ước tính, có thể null nếu không xác định được
  publishedAt DateTime? // Thời gian publish bài viết, có thể null nếu chưa publish
  createdAt DateTime @default(now())
  updatedAt DateTime  @default(now())

  user User  @relation(fields: [userId], references: [id]) //  Khai báo quan hệ: `userId` trong Post trỏ tới `id` trong User 

  @@map("posts") // Đặt tên bảng trong database là "posts"
}


model Comment {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt // khóa ngoại liên kết đến User
  createdAt DateTime @default(now())
  updatedAt DateTime  @default(now())

  user User  @relation(fields: [userId], references: [id]) //  Khai báo quan hệ: `userId` trong Post trỏ tới `id` trong User 

  @@map("comment") // Đặt tên bảng trong database là "comment"
}
